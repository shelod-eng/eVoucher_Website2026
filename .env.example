NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

PAYMENTS_WEBHOOK_SECRET=replace-with-strong-secret
PAYMENT_MODE=production
PAYMENT_SANDBOX_ENABLED=false
PAYMENT_SANDBOX_UI_ENABLED=false
PAYMENT_SANDBOX_WEBHOOK_SECRET=
PAYMENT_SANDBOX_ALLOWED_ORIGINS=
PAYMENT_SANDBOX_DEFAULT_SCENARIO=card_success
PAYMENT_SANDBOX_CALLBACK_BASE_URL=
PAYMENT_SANDBOX_LATENCY_MS=0
PAYMENT_SANDBOX_ROLE_ALLOWLIST=admin,qa,finance

OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key

NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your-google-analytics-id
NEXT_PUBLIC_ADSENSE_ID=your-adsense-id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
NEXT_PUBLIC_SUPPORT_WHATSAPP_NUMBER=0695831160

# Optional: override recipients for approval confirmation copy email.
# Defaults to shelod@gmail.com when unset.
MERCHANT_APPROVAL_CONFIRMATION_RECIPIENTS=

# -----------------------------------------------------------------------------
# Billing Engine (BankServ + RBAC)
# -----------------------------------------------------------------------------

# Portal API header auth (used by billing-engine-portal)
PORTAL_ADMIN_PASSCODE=replace-with-strong-passcode

# Required for encrypting bank account numbers at rest (AES-256-GCM).
# Generate 32 random bytes (64 hex chars).
BILLING_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
BILLING_ENCRYPTION_KEY_ID=v1

# AVS mode: mock | real
BILLING_AVS_MODE=mock

# BankServ submission mode: mock | real
BILLING_BANKSERV_MODE=mock

# Allow mock endpoints (dev/staging only)
BILLING_ENABLE_MOCK_ENDPOINTS=true

# FNB CIB integration (only required when BILLING_BANKSERV_MODE=real)
FNB_CIB_API_URL=
FNB_CIB_API_KEY=
FNB_CIB_CLIENT_ID=
FNB_SPONSOR_ACCOUNT=
